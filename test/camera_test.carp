(load "Test.carp")
(use Test)
(load "camera.carp")
(use Camera)
(use Vector3)

(deftest camera-test
  (let [state (Test.State.init 0 0)]
    (do
      ;; Matrix Identity Test
      (let [m (CameraMat4.identity)
            data (CameraMat4.data &m)]
        (do
          (set! state (Test.assert-equal &state 1.0f @(Array.unsafe-nth data 0)  "Identity [0] is 1"))
          (set! state (Test.assert-equal &state 1.0f @(Array.unsafe-nth data 5)  "Identity [5] is 1"))
          (set! state (Test.assert-equal &state 1.0f @(Array.unsafe-nth data 10) "Identity [10] is 1"))
          (set! state (Test.assert-equal &state 1.0f @(Array.unsafe-nth data 15) "Identity [15] is 1"))))

      ;; Camera Test
      (let [pos (Vector3.init 0.0 0.0 10.0)
            cam (Camera.new pos -90.0 0.0 1.77)
            view (Camera.look-at &cam)
            proj (Camera.perspective &cam)]
        (do
          (set! state (Test.assert-equal &state 16 (Array.length (CameraMat4.data &view)) "View matrix has 16 elements"))
          (set! state (Test.assert-equal &state 16 (Array.length (CameraMat4.data &proj)) "Proj matrix has 16 elements"))))
      
      state)))
